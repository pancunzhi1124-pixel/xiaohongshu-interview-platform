DASHSCOPE_API_KEY=your_dashscope_api_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus

# 默认实时字幕方案
ASR_PROVIDER=browser_realtime
REALTIME_ASR_MODEL=paraformer-realtime-8k-v2

# 可选：如果后续确认 DashScope realtime 可以安全浏览器直连，再切换
# ASR_PROVIDER=dashscope_realtime

# 可选 fallback：旧文件转写，不作为默认
FILE_ASR_PROVIDER=disabled

# optional Iflytek fallback, default disabled
IFLYTEK_RAASR_APP_ID=
IFLYTEK_RAASR_SECRET_KEY=
IFLYTEK_RAASR_API_URL=https://raasr.xfyun.cn/v2/api

# deprecated OSS variables (not required for default path)
# ALIYUN_OSS_ACCESS_KEY_ID=
# ALIYUN_OSS_ACCESS_KEY_SECRET=
# ALIYUN_OSS_BUCKET=
# ALIYUN_OSS_REGION=
# ALIYUN_OSS_ENDPOINT=
# ALIYUN_OSS_SECURE=
