DASHSCOPE_API_KEY=your_dashscope_api_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus

ASR_PROVIDER=dashscope
ASR_MODEL=paraformer-v2

ALIYUN_OSS_ACCESS_KEY_ID=your_oss_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
ALIYUN_OSS_BUCKET=your_oss_bucket
ALIYUN_OSS_REGION=oss-cn-beijing
# 或使用：
# ALIYUN_OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
ALIYUN_OSS_SECURE=true

# optional fallback
IFLYTEK_RAASR_APP_ID=
IFLYTEK_RAASR_SECRET_KEY=
IFLYTEK_RAASR_API_URL=https://raasr.xfyun.cn/v2/api
